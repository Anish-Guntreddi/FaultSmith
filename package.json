{
  "name": "faultsmith",
  "version": "0.1.0",
  "description": "AI-powered deliberate debugging labs with validated failures and evidence-based assessment.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anish-Guntreddi/FaultSmith.git"
  },
  "bugs": {
    "url": "https://github.com/Anish-Guntreddi/FaultSmith/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "security:bundle": "node scripts/check-client-bundle.mjs",
    "quality": "npm run lint && npm run typecheck && npm test && npm run build && npm run security:bundle && npm run test:e2e"
  },
  "dependencies": {
    "next": "16.2.10",
    "openai": "^6.32.0",
    "react": "19.2.7",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
