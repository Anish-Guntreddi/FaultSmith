{
  "name": "faultsmith",
  "version": "0.1.0",
  "description": "AI-powered deliberate debugging labs with validated failures and evidence-based assessment.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anish-Guntreddi/FaultSmith.git"
  },
  "bugs": {
    "url": "https://github.com/Anish-Guntreddi/FaultSmith/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:firebase": "firebase emulators:exec --project demo-faultsmith --only auth,firestore \"vitest run --config vitest.firebase.config.mts\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:firebase": "firebase emulators:exec --project demo-faultsmith --only auth,firestore \"playwright test --config playwright.firebase.config.ts\"",
    "security:source": "node scripts/check-source-security.mjs",
    "security:bundle": "node scripts/check-client-bundle.mjs",
    "smoke:fallback": "node scripts/live-smoke.mjs",
    "smoke:live": "node scripts/live-smoke.mjs --live",
    "smoke:production": "node scripts/production-smoke.mjs",
    "readiness:prepare": "node scripts/submission-readiness.mjs --prepare",
    "readiness:strict": "node scripts/submission-readiness.mjs --strict",
    "quality": "npm run lint && npm run typecheck && npm test && npm run test:firebase && npm run build && npm run security:bundle && npm run test:e2e"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "next": "16.2.10",
    "openai": "^6.32.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "firebase-tools": "15.24.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "postcss": "8.5.19",
    "uuid": "^11.1.1"
  }
}
