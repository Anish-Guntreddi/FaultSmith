rules_version = '2';

// FaultSmith learning data is written and read exclusively by the server
// through the Admin SDK (which bypasses these rules). Browsers never talk to
// Firestore directly, so every direct client read and write is denied — even
// for an authenticated, email-verified account operating on its own UID.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
