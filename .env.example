# Server-only credential. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Public canonical origin used to resolve social preview image URLs. Set this
# to the final Netlify site origin for production (for example,
# https://your-site.netlify.app). Local builds safely default to localhost.
NEXT_PUBLIC_SITE_URL=

# --- Optional Firebase cloud progress (disabled by default) ---
# Leave every value below empty to keep FaultSmith fully local. The app must
# build, start, and serve the guest learning path with all of these unset.

# Cloud progress feature flag. Only the exact value "true" enables cloud sync.
NEXT_PUBLIC_FAULTSMITH_CLOUD_SYNC=

# Public Firebase web configuration. These values are inlined into the browser
# bundle at build time by design. They identify the Firebase project and are
# public metadata, NOT authorization; data access is enforced server-side.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only Firebase values. Never prefix these with NEXT_PUBLIC_.
FIREBASE_PROJECT_ID=
# Single server-only service-account secret (JSON provided privately by the
# host environment). Never commit a value or a service-account file.
FIREBASE_SERVICE_ACCOUNT=
